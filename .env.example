# Plantilla de secretos locales — cliente minera, producto Illari.
# Copiar este archivo a .env y completar los valores reales.
# El archivo .env está en .gitignore y NO se sube al repo.
#
# Uso:
#   cp .env.example .env
#   # editar .env con los valores reales
#   bash scripts/run_e2e_escritura.sh
#   bash scripts/run_e2e_lectura.sh [--llm eco|stub|gemini]

# MASTER_SECRET: clave maestra de cifrado de chunks (obligatoria).
# Debe coincidir exactamente con el valor del deploy activo.
# Mínimo 32 bytes. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MASTER_SECRET=reemplazar_con_el_valor_real

# GEMINI_API_KEY: clave API de Google Gemini (obligatoria solo con --llm gemini).
# Obtener en https://aistudio.google.com/app/apikey
# Dejar vacío o comentar si no se usa Gemini.
GEMINI_API_KEY=
